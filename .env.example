# ---------------------------------------------------------------------------
# Mohalla — environment variables. Copy to ".env" and fill in.
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
# Free cloud DB (recommended): create one at https://neon.tech and paste it here
# (use the DIRECT connection string — turn OFF "Pooled connection").
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Secret used to sign admin session cookies. Generate with: openssl rand -base64 32
AUTH_SECRET="dev-only-change-me"

# Initial admin account (created by the seed / setup endpoint).
ADMIN_EMAIL="admin@mohalla.app"
ADMIN_PASSWORD="ChangeMe!2024"

# Protects the one-time /api/setup?key=... seed endpoint (optional on a fresh DB).
SETUP_KEY="change-me-to-a-long-random-string"
